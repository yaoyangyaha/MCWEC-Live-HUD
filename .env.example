# Copy this file to .env and adjust the values for your event.

MCWEC_TITLE=MCWEC Live Timing
MCWEC_SESSION=RACE
MCWEC_TRACK_NAME=Minecraft Circuit
MCWEC_TOTAL_LAPS=20

# Optional: Java Edition client log watcher (reads latest.log and parses lines containing "[HUD]")
# Example (Windows):
# MCWEC_JAVA_LOG_DIR=H:\我的世界\MINECRAFT PCL\.minecraft\versions\Formula 1\logs
# MCWEC_JAVA_LOG_FILE=latest.log
